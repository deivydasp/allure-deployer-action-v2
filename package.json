{
  "name": "allure-deployer-action",
  "version": "2.0.0",
  "description": "Deploy Allure test reports to GitHub Pages with history and report aggregation",
  "main": "./dist/index.js",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/deivydasp/allure-deployer-action"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "lint": "eslint src/",
    "build": "rm -rf ./dist && tsc -p tsconfig.json && ncc build dist/index.js -o dist/main -e allure -e @allurereport/summary && ncc build dist/utilities/cleanup.js -o dist/cleanup && node scripts/patch-dist-package.js && cd dist/main && npm install allure@~3.3.1 --omit=dev --silent",
    "build:watch": "tsc --watch",
    "test": "npx vitest run",
    "test:watch": "npx vitest"
  },
  "type": "module",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0",
    "@octokit/request-error": "^7.1.0",
    "allure": "~3.3.1",
    "normalize-url": "^9.0.0",
    "p-limit": "^7.3.0",
    "properties-reader": "^3.0.1",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
