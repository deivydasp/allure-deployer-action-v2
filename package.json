{
  "name": "allure-deployer-action",
  "version": "1.0.0",
  "description": "Host Allure test reports on the web with history, retries, and Slack integration—no server required",
  "main": "./dist/index.js",
  "scripts": {
    "lint": "eslint src/",
    "build": "rm -rf ./dist && tsc -p tsconfig.json && ncc build dist/index.js -o dist/main && ncc build dist/utilities/cleanup.js -o dist/cleanup",
    "build:watch": "tsc --watch"
  },
  "type": "module",
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@octokit/request-error": "^7.1.0",
    "@octokit/rest": "^22.0.1",
    "@slack/web-api": "^7.15.0",
    "allure-commandline": "^2.38.1",
    "normalize-url": "^9.0.0",
    "p-limit": "^7.3.0",
    "properties-reader": "^3.0.1",
    "simple-git": "^3.33.0",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/unzipper": "^0.10.11",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
